@model CustomerAccountManagement.ViewModels.Invoices.InvoiceIndexViewModel
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>Invoices</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Invoice
    </a>
</div>

{{-- Filter panel --}}
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold mb-1">Filter by Client</label>
                <select name="clientId" class="form-select">
                    @foreach (var item in Model.ClientOptions)
                    {
                        <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold mb-1">Filter by Currency</label>
                <select name="currency" class="form-select">
                    @foreach (var item in Model.CurrencyOptions)
                    {
                        <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-auto d-flex gap-2 pb-1">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i>Reset
                </a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Invoices.Any())
{
    <div class="alert alert-info">
        No invoices found.
        @if (Model.SelectedClientId.HasValue || !string.IsNullOrEmpty(Model.SelectedCurrency))
        {
            <a asp-action="Index">Clear filters</a>
        }
        else
        {
            <a asp-action="Create">Create the first one.</a>
        }
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Client</th>
                        <th>Email</th>
                        <th>Amount</th>
                        <th style="width:90px">Currency</th>
                        <th>PDF File</th>
                        <th style="width:140px">Created</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.Invoices)
                    {
                        <tr>
                            <td class="text-muted">@inv.Id</td>
                            <td class="fw-semibold">@inv.ClientName</td>
                            <td class="text-muted small">@inv.ClientEmail</td>
                            <td>@inv.Amount.ToString("N2")</td>
                            <td><span class="badge bg-secondary fs-6 fw-normal">@inv.Currency</span></td>
                            <td>
                                <a href="/uploads/@inv.StoredFileName"
                                   target="_blank"
                                   class="text-decoration-none small"
                                   title="@inv.OriginalFileName">
                                    <i class="bi bi-file-earmark-pdf text-danger me-1"></i>@inv.OriginalFileName
                                </a>
                            </td>
                            <td class="text-muted small">@inv.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@inv.Id"
                                      method="post"
                                      onsubmit="return confirm('Delete invoice #@inv.Id?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted small mt-2">Total: @Model.Invoices.Count invoice(s)</p>
}
